{
  "name": "mcp-guardian",
  "version": "1.0.0",
  "description": "Security middleware proxy for MCP servers — intercepts tool calls, enforces policies, redacts secrets, and logs everything.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-guardian": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "security",
    "proxy",
    "middleware",
    "audit",
    "rate-limiting",
    "redaction"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "guardian.example.yaml",
    "README.md",
    "LICENSE"
  ]
}
